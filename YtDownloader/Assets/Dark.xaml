<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════
         PALETTE — Dark
    ═══════════════════════════════════════ -->
    <Color x:Key="BgDeepColor">#0D0F14</Color>
    <Color x:Key="BgSurfaceColor">#161921</Color>
    <Color x:Key="BgCardColor">#1E2130</Color>
    <Color x:Key="BgHoverColor">#252840</Color>
    <Color x:Key="AccentColor">#FF3B5F</Color>
    <Color x:Key="AccentDimColor">#CC2A4A</Color>
    <Color x:Key="AccentGlowColor">#44FF3B5F</Color>
    <Color x:Key="TextPrimaryColor">#F0F2FF</Color>
    <Color x:Key="TextSecondaryColor">#8B90A8</Color>
    <Color x:Key="TextMutedColor">#4A4F6A</Color>
    <Color x:Key="BorderColor">#252840</Color>
    <Color x:Key="BorderBrightColor">#3A3F5C</Color>
    <Color x:Key="SuccessColor">#00C78C</Color>
    <Color x:Key="WarningColor">#FFB020</Color>
    <Color x:Key="ErrorColor">#FF4757</Color>

    <SolidColorBrush x:Key="BgDeep"      Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgSurface"   Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgCard"      Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgHover"     Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="Accent"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDim"   Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="AccentGlow"  Color="{StaticResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMuted"   Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="Border"      Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderBright" Color="{StaticResource BorderBrightColor}"/>
    <SolidColorBrush x:Key="Success"     Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="Warning"     Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="Error"       Color="{StaticResource ErrorColor}"/>

    <!-- Translucent variants used by the Badge* styles (Base.xaml) -->
    <SolidColorBrush x:Key="SuccessSubtle" Color="#1A00C78C"/>
    <SolidColorBrush x:Key="WarningSubtle" Color="#1AFFB020"/>
    <SolidColorBrush x:Key="ErrorSubtle"   Color="#1AFF4757"/>
    <SolidColorBrush x:Key="AccentSubtle"  Color="#1AFF3B5F"/>

</ResourceDictionary>
