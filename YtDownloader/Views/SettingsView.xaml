<UserControl x:Class="YtDownloader.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:YtDownloader.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:InvertBoolConverter x:Key="InvBool"/>
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringVis"/>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource MinimalScrollViewer}" Margin="24">
        <StackPanel MaxWidth="640">

            <!-- Page title -->
            <TextBlock Text="Configuración"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="{StaticResource FontMD}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,24"/>

            <!-- ─── PATHS SECTION ─── -->
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="20"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Carpetas de destino"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="{StaticResource FontBase}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Video folder -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Videos"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding OutputFolder}"
                                     IsReadOnly="True"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Content="Examinar"
                                    Command="{Binding BrowseOutputFolderCommand}"
                                    Padding="14,10"/>
                        </Grid>
                    </StackPanel>

                    <!-- Audio folder -->
                    <StackPanel>
                        <TextBlock Text="Audio (MP3)"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding AudioOutputFolder}"
                                     IsReadOnly="True"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource GhostButton}"
                                    Content="Examinar"
                                    Command="{Binding BrowseAudioFolderCommand}"
                                    Padding="14,10"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── DOWNLOAD SECTION ─── -->
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="20"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Descarga"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="{StaticResource FontBase}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <!-- Concurrent downloads -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Descargas simultáneas"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding ConcurrencyOptions}"
                                  SelectedItem="{Binding MaxConcurrent}"
                                  Width="120" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Video format -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Formato de video preferido"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding VideoExtensions}"
                                  SelectedItem="{Binding PreferredVideoExt}"
                                  Width="120" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Checkboxes -->
                    <CheckBox Style="{StaticResource ModernCheckBox}"
                              Content="Incrustar miniatura en el archivo"
                              IsChecked="{Binding EmbedThumbnail}"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,0,0,10"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}"
                              Content="Incrustar metadatos (título, canal, fecha…)"
                              IsChecked="{Binding EmbedMetadata}"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,0,0,10"/>
                    <CheckBox Style="{StaticResource ModernCheckBox}"
                              Content="Descargar subtítulos automáticos"
                              IsChecked="{Binding AddSubtitles}"
                              Foreground="{StaticResource TextSecondary}"/>

                    <!-- Subtitle languages (conditional) -->
                    <StackPanel Visibility="{Binding AddSubtitles, Converter={StaticResource BoolVis}}"
                                Margin="0,14,0,0">
                        <TextBlock Text="Idiomas de subtítulos (separados por coma)"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SubtitleLanguage}"
                                 Width="200" HorizontalAlignment="Left"
                                 Tag="ej: es,en,pt"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── AUDIO SECTION ─── -->
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="20"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Audio"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="{StaticResource FontBase}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Formato de audio"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="{StaticResource FontSM}"
                                       Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding AudioFormats}"
                                      SelectedItem="{Binding AudioFormat}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Calidad de audio (kbps)"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="{StaticResource FontSM}"
                                       Margin="0,0,0,6"/>
                            <ComboBox Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding AudioQualities}"
                                      SelectedItem="{Binding AudioQuality}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── APPEARANCE / NOTIFICATIONS SECTION ─── -->
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="20"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Apariencia y notificaciones"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="{StaticResource FontBase}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Tema"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding Theme}"
                                  Width="120" HorizontalAlignment="Left"
                                  Margin="0,0,0,6"/>
                        <TextBlock Text="El tema se aplica al reiniciar la app."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="{StaticResource FontXS}"/>
                    </StackPanel>

                    <CheckBox Style="{StaticResource ModernCheckBox}"
                              Content="Notificar al completar una descarga"
                              IsChecked="{Binding NotifyOnComplete}"
                              Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Border>

            <!-- ─── YT-DLP SECTION ─── -->
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="20"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="yt-dlp"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="{StaticResource FontBase}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <CheckBox Style="{StaticResource ModernCheckBox}"
                              Content="Actualizar yt-dlp automáticamente al iniciar"
                              IsChecked="{Binding AutoUpdateYtDlp}"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource GhostButton}"
                                Content="Actualizar ahora"
                                Command="{Binding UpdateYtDlpCommand}"
                                IsEnabled="{Binding IsUpdating, Converter={StaticResource InvBool}}"
                                Padding="14,10"
                                Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding UpdateStatus}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding UpdateStatus, Converter={StaticResource EmptyStringVis}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── PROXY SECTION ─── -->
            <Border Background="{StaticResource BgCard}" CornerRadius="10" Padding="20"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Red / Proxy"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="{StaticResource FontBase}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <CheckBox Style="{StaticResource ModernCheckBox}"
                              Content="Usar proxy"
                              IsChecked="{Binding UseProxy}"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,0,0,14"/>

                    <StackPanel Visibility="{Binding UseProxy, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="URL del proxy"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="{StaticResource FontSM}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ProxyUrl}"
                                 Tag="http://user:pass@host:port"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── SAVE BUTTON ─── -->
            <Button Style="{StaticResource PrimaryButton}"
                    Content="Guardar configuración"
                    Command="{Binding SaveSettingsCommand}"
                    HorizontalAlignment="Left"
                    Padding="24,12"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
